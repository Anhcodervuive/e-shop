<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="x-apple-disable-message-reformatting" />
    <title>Verify Your Email</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f3f6fb;
        font-family: Arial, Helvetica, sans-serif;
        color: #1f2937;
      }
      table {
        border-spacing: 0;
      }
      .wrapper {
        width: 100%;
        table-layout: fixed;
        background-color: #f3f6fb;
        padding: 24px 12px;
      }
      .container {
        width: 100%;
        max-width: 620px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.1);
      }
      .header {
        padding: 28px 28px 20px;
        background: linear-gradient(135deg, #0f172a, #1d4ed8);
        color: #ffffff;
      }
      .brand {
        margin: 0;
        font-size: 20px;
        font-weight: 700;
        letter-spacing: 0.4px;
      }
      .header-sub {
        margin: 8px 0 0;
        font-size: 14px;
        opacity: 0.9;
        line-height: 1.5;
      }
      .content {
        padding: 28px;
      }
      .title {
        margin: 0 0 10px;
        font-size: 24px;
        line-height: 1.3;
        color: #111827;
      }
      .text {
        margin: 0 0 14px;
        font-size: 15px;
        line-height: 1.7;
        color: #4b5563;
      }
      .otp-box {
        margin: 22px 0;
        padding: 18px;
        border-radius: 14px;
        border: 1px dashed #2563eb;
        background: #eff6ff;
        text-align: center;
      }
      .otp-label {
        margin: 0 0 8px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #1d4ed8;
        font-weight: 700;
      }
      .otp-code {
        margin: 0;
        font-size: 34px;
        line-height: 1.1;
        letter-spacing: 8px;
        font-weight: 800;
        color: #0f172a;
      }
      .note {
        margin: 12px 0 0;
        font-size: 13px;
        line-height: 1.6;
        color: #6b7280;
      }
      .footer {
        padding: 18px 28px 24px;
        border-top: 1px solid #e5e7eb;
        font-size: 12px;
        color: #9ca3af;
        line-height: 1.6;
      }
      @media only screen and (max-width: 600px) {
        .header,
        .content,
        .footer {
          padding-left: 18px !important;
          padding-right: 18px !important;
        }
        .title {
          font-size: 21px !important;
        }
        .otp-code {
          font-size: 30px !important;
          letter-spacing: 6px !important;
        }
      }
    </style>
  </head>
  <body>
    <table role="presentation" class="wrapper" width="100%">
      <tr>
        <td align="center">
          <table role="presentation" class="container" width="100%">
            <tr>
              <td class="header">
                <h1 class="brand">E Multi Vendor Shop</h1>
                <p class="header-sub">Secure account verification</p>
              </td>
            </tr>
            <tr>
              <td class="content">
                <h2 class="title">Hi <%= name || 'there' %>,</h2>
                <p class="text">
                  Thanks for registering. Please use the OTP code below to verify your email address and activate your account.
                </p>

                <div class="otp-box">
                  <p class="otp-label">Your OTP Code</p>
                  <p class="otp-code"><%= otp %></p>
                  <p class="note">This code will expire in 5 minutes.</p>
                </div>

                <p class="text">
                  If you did not request this email, you can safely ignore it.
                </p>
              </td>
            </tr>
            <tr>
              <td class="footer">
                This is an automated message from E Multi Vendor Shop. Please do not reply directly to this email.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
